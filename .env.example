# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Safety limits
ANALYTICS_MAX_ROWS=50

# Leave these empty for "anonymous mode", or set them to enforce auth.
COPILOT_API_KEYS=["dev-key"]
COPILOT_API_KEY_MAP={"dev-key":"ohoushyar"}

# CLI uses this to send requests:
# COPILOT_API_KEY=dev-key